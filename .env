SWAGGER_COVERAGE_SERVICES='[
    {
        "key": "api-service",
        "name": "API Service",
        "tags": ["API", "PRODUCTION"],
        "repository": "https://github.com/Vitaly-Miller/autotests-api-httpx",
        "swagger_url": "http://localhost:8000/openapi.json"
    }
]'
