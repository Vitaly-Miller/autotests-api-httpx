HTTPX_CLIENT.BASE_URL='http://localhost:8000'
HTTPX_CLIENT.TIMEOUT=5.0

TEST_DATA.IMAGE_PNG_FILE='testdata/files/test_image.png'

#------------------------------------- Swagger Coverage Tool (Покрытие требований) -------------------------------------
